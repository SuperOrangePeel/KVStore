# ------------- 自定义配置区（可根据需求修改）-------------
CC := gcc  # 编译器（可替换为 clang 等）
INCDIR := ./include  # 头文件目录（如果有自定义头文件，修改此处，无则注释）
# 头文件编译参数（-I 指定头文件搜索路径）
INCFLAGS := $(if $(INCDIR),-I$(INCDIR),)

# ------------- 自动识别文件 -------------
SRCS := $(wildcard *.c)  # 所有 .c 源文件
EXES := $(patsubst %.c,%,$(SRCS))  # 所有对应可执行文件

# ------------- 核心目标 -------------
all: $(EXES)

# ------------- 单个文件编译规则 -------------
%: %.c
	$(CC) $(CFLAGS) $(INCFLAGS) $< -o $@
# ------------- 清理规则 -------------
clean:
	rm -rf $(EXES)  # 删除可执行文件
	rm -rf *.o      # 若生成 .o 目标文件，一并删除（本Makefile未生成，可选保留）

# ------------- 伪目标声明 -------------
.PHONY: all clean